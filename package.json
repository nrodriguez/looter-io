{
  "private": true,
  "scripts": {
    "dev": "next dev -H ::",
    "dev:debug:ebay": "DEBUG=ebay:* dev ",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --pretty --noEmit",
    "format": "prettier --write .",
    "lint": "eslint . --ext ts --ext tsx --ext js",
    "test": "jest",
    "test-all": "yarn lint && yarn type-check && yarn test"
